{
  "$schema": "https://schemas.runtipi.io/dynamic-compose.json",
  "services": [
    {
      "name": "openscrub",
      "image": "pharmhero/openscrub:latest",
      "isMain": true,
      "internalPort": 8384,
      "command": "openscrub-web --host 0.0.0.0 --http",
      "volumes": [
        { "hostPath": "${APP_DATA_DIR}/data", "containerPath": "/root/.local/share/OpenScrub" }
      ]
    }
  ]
}
